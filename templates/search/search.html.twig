{% extends 'base.html.twig' %}

{% block title %}Search{% if query %}: {{ query }}{% endif %} | Aperture Science Store{% endblock %}

{% block body %}
    {% include 'shared/layout/header.html.twig' %}

    <main id="main-content">
        <section class="border-b border-aperture-line bg-aperture-panel py-12">
            <div class="ap-container">
                <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-aperture-blue">Search</p>
                <h1 class="mt-4 font-display text-5xl font-black uppercase leading-none tracking-tight text-aperture-dark">
                    {% if query %}
                        {{ query }}
                    {% else %}
                        Product Search
                    {% endif %}
                </h1>
            </div>
        </section>

        {% include 'category/sections/product-listing.html.twig' with {
            category: { name: 'products' },
            products: products,
            productCount: productCount,
            listingSummary: query
                ? 'Showing ' ~ productCount ~ ' result' ~ (productCount == 1 ? '' : 's') ~ ' for "' ~ query ~ '"'
                : 'Enter a search term to find products.',
            emptyMessage: query ? 'No products matched your search.' : 'Enter a search term to find products.'
        } only %}
    </main>

    {% include 'shared/layout/footer.html.twig' %}
{% endblock %}
